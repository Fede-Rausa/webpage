partito = c('fratelli', 'lega', 'fi', 'futuro nazionale', 'azione', 'Italia viva', 'noi moderati', 'più eu', 'pd','5s', 'alleanza verdi'),
share = c(0.288, 0.065,0.087,0.032,0.033,0.022,0.011,0.016,0.216,0.124,0.067),
partecipazione = c(0.59,0.44,0.45,0.45,0.51,0.51,0.45,0.51,0.63,0.57,0.51),
vota_si = c(1,1,1,1,1,0.5,1,1,0,0,0)
)
df2$vota_no = 1 - df2$vota_si
DT::datatable(df2)
