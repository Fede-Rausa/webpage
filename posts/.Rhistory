score_si = sum(df2$vota_si * df2$share * df2$partecipazione)
score_no = sum(df2$vota_no * df2$share * df2$partecipazione)
den = score_si + score_no
ratio_si = score_si / den
ratio_no = score_no / den
print(paste0('score per il si: ', score_si))
print(paste0('score per il no: ', score_no))
print(paste0('stima di voto per il si: ', ratio_si))
print(paste0('stima di voto per il no: ', ratio_no))
