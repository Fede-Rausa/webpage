versiera_agnesi = function(x,r){
r2 = r*r
r3 = r2*r
d = (8*r3)/(x^2+4*r2)
return(d)
}
r = 0.1
curve(function(x){return(versiera_agnesi(x, r))}, from=-100, to=100)
function(x){return(versiera_agnesi(x, r))}
myf = function(x){return(versiera_agnesi(x, r))}
curve(myf(x), from=-100, to=100)
