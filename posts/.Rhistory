simula_referendum = function(n_elettori=100, prob_partito, prob_vota, prob_si){
partiti = rmultinom(n=n_elettori, size = 1, prob=prob_partito)
n_si = 0
n_no = 0
astenuti = 0
for (i in 1:n_elettori){
id_partito = which(as.logical(partiti[,i]))
si_astiene = rbinom(n=1, size=1, prob=prob_vota[id_partito])
if (si_astiene==0){
vota_si = rbinom(n=1, size=1, prob=prob_si[id_partito])
if (vota_si==1){
n_si = n_si + 1
}else{
n_no = n_no + 1
}
}else{
astenuti = astenuti+1
}
}
return(list(n_si=n_si, n_no=n_no, astenuti=astenuti, si_ratio = n_si/(n_si+n_no)))
}
simula_referendum = function(n_elettori=100, prob_partito, prob_vota, prob_si){
partiti = rmultinom(n=n_elettori, size = 1, prob=prob_partito)
n_si = 0
n_no = 0
astenuti = 0
for (i in 1:n_elettori){
id_partito = which(as.logical(partiti[,i]))
si_astiene = rbinom(n=1, size=1, prob=prob_vota[id_partito])
if (si_astiene==0){
vota_si = rbinom(n=1, size=1, prob=prob_si[id_partito])
if (vota_si==1){
n_si = n_si + 1
}else{
n_no = n_no + 1
}
}else{
astenuti = astenuti+1
}
}
r_si = n_si/(n_si+n_no)
r_no = 1 - r_si
r_astenuti = astenuti/n_elettori
return(list(n_si=n_si, n_no=n_no, n_astenuti=astenuti,
r_si = r_si, r_no = r_no, r_astenuti=r_astenuti))
}
