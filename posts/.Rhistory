col = colorRampPalette(c("blue", 'yellow', 'orange', 'red'))(100)
T = 5;d = exp(-x/T); d=d/sum(d);plot(x,d, type='l', xlim=c(0,100), ylim=c(0,1), col='white', xlab='energy', ylab='cdf', main='Boltzmann Distribution - CDF')
for (t in 1:length(col)){T = t*2;d = exp(-x/T);d=d/sum(d);d = cumsum(d); lines(x,d, type='l', col=col[t])}
