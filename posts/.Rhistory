versiera_agnesi = function(x,r){
r2 = r*r
r3 = r2*r
d = (8*r3)/(x^2+4*r2)
d = d / (4*pi*r2)
return(d)
}
versiera_cauchy = function(x,r){
d=dcauchy(x, location = 0, scale = 2*r)
return(d)
}
