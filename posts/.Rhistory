myk = quantile(x, seq(0,1,0.1))
xmat = rep(1,N)
for (k in myk){
hinge_a = x - k
hinge_b = k - x
hinge_a[hinge_a<0] = 0
hinge_b[hinge_b<0] = 0
xmat = cbind(xmat, hinge_a, hinge_b)
}
df = data.frame(y=y)
colnames(xmat) = paste0(colnames(xmat),1:ncol(xmat))
spline = lm(y~., data=df)
plot(x,y)
abline(spline, col='red')
summary(spline)
df = data.frame(y=y)
colnames(xmat) = paste0(colnames(xmat),1:ncol(xmat))
df = cbind(df, xmat)
